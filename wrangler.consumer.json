{
  "name": "mvpilot-consumer",
  "main": "workers/consumer.ts",
  "compatibility_date": "2025-05-12",
  "compatibility_flags": ["nodejs_compat"],

  "alias": {
    "$lib": "./src/lib"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mvpilot",
      "database_id": "PLACEHOLDER_DATABASE_ID"
    }
  ],

  "queues": {
    "consumers": [
      {
        "queue": "mvpilot-jobs",
        "max_batch_size": 1,
        "max_retries": 3
      }
    ]
  }
}
